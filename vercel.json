{
  "buildCommand": "pip install -r requirements.txt",
  "outputDirectory": ".",
  "env": {
    "FLASK_APP": "api/index.py"
  },
  "functions": {
    "api/**/*.py": {
      "memory": 3008,
      "maxDuration": 60,
      "runtime": "python3.12"
    }
  },
  "routes": [
    {
      "src": "/.*",
      "dest": "api/index.py"
    }
  ]
}
